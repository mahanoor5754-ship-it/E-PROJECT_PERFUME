// cart
$(document).ready(function() {
    let cart = [];

    // 1. Buy Now Click Event
    $(document).on('click', '.buy-now', function(e) {
        e.preventDefault();
        let itemName = $(this).attr('data-name'); 
        let itemPrice = $(this).attr('data-price');

        if (itemName && itemPrice) {
            cart.push({ 
                name: itemName, 
                price: parseFloat(itemPrice) 
            });
            updateCartModal();
            
            // Button Feedback
            let btn = $(this);
            btn.text("Added!").css("border-color", "#d4af37");
            setTimeout(() => btn.text("Buy Now").css("border-color", "#333"), 800);
        }
    });

    // 2. Cancel/Remove Button Event
    $(document).on('click', '.remove-item', function() {
        // Index get karein ke kaunsa item delete karna hai
        let index = $(this).data('index');
        
        // Array se item nikal dein
        cart.splice(index, 1);
        
        // Modal aur badge update karein
        updateCartModal();
    });

    // 3. Update Modal Function
    function updateCartModal() {
        let html = '';
        let total = 0;

        // Update Badge Count
        $('#cart-count').text(cart.length);

        if (cart.length === 0) {
            html = '<p class="text-center text-muted py-3">Your cart is empty.</p>';
        } else {
            cart.forEach((item, index) => {
                html += `
                <div class="d-flex justify-content-between align-items-center py-3 border-bottom border-secondary">
                    <div>
                        <span class="text-white d-block">${item.name}</span>
                        <span style="color: #d4af37; font-size: 14px;">$${item.price.toFixed(2)}</span>
                    </div>
                    <button class="btn btn-sm remove-item" data-index="${index}" style="color: #ff4d4d; border: 1px solid #444; background: transparent;">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>`;
                total += item.price;
            });
        }

        $('#cart-items-list').html(html);
        $('#total-price').text(total.toFixed(2));
    }
});













